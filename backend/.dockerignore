# =============================================================================
# Allmart Backend — .dockerignore
# Archivos y carpetas excluidos del contexto de build de Docker.
# NOTA: Reduce el tamaño del contexto de build significativamente
# =============================================================================

# Dependencias
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
*.tsbuildinfo

# Git
.git
.gitignore
.gitattributes
.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Documentación (excepto README si es necesario)
docs/
*.md
!README.md
!CHANGELOG.md

# Tests
coverage/
.nyc_output/
test-results/
__tests__/

# Logs
logs/
*.log

# Environment (excepto ejemplos)
.env
.env.local
.env.*.local
!.env.example

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile

# Temporales
tmp/
temp/
*.tmp
.cache/

# Misc
.prettierrc
.eslintrc*
tsconfig*.json
vitest.config.ts
jest.config.js
.npmrc
