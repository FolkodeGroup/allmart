const MAX_TITLE_LENGTH = 80;
const MAX_SHORT_DESCRIPTION_LENGTH = 200;
const OPTIMIZED_IMAGE_SIZE = 300;
const IMAGE_PREPARATION_CONCURRENCY = 4;

export interface CatalogPdfBranding {
  primary: string;
  primaryDark: string;
  primaryLight: string;
  accent: string;
  accentDark: string;
  background: string;
  surface: string;
  border: string;
  textPrimary: string;
  textSecondary: string;
  headingFont: string;
  bodyFont: string;
}

export interface CatalogPdfProductInput {
  id?: string;
  title?: string;
  name?: string;
  price: number | string;
  currency?: string;
  shortDescription?: string | null;
  description?: string | null;
  imageUrl?: string | null;
  images?: string[] | null;
}

export interface CatalogPdfProduct {
  id?: string;
  title: string;
  price: number;
  currency: string;
  formattedPrice: string;
  shortDescription: string;
  imageUrl?: string;
  imageAlt: string;
}

interface CatalogRenderableProduct extends CatalogPdfProduct {
  imageDataUri: string;
}

export interface GenerateCatalogPdfOptions {
  products: CatalogPdfProductInput[];
  baseUrl?: string;
  paperFormat?: 'A4' | 'Letter';
  columns?: 2 | 3;
  title?: string;
  subtitle?: string;
  locale?: string;
  defaultCurrency?: string;
  contactText?: string;
  savePath?: string;
  branding?: Partial<CatalogPdfBranding>;
}

export const DEFAULT_CATALOG_BRANDING: CatalogPdfBranding = {
  primary: '#769282',
  primaryDark: '#5d7568',
  primaryLight: '#8fa99a',
  accent: '#DDB08C',
  accentDark: '#c89a70',
  background: '#F2EFEB',
  surface: '#FFFFFF',
  border: '#E5E2DD',
  textPrimary: '#1A1A1A',
  textSecondary: '#767676',
  headingFont: "'Montserrat', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif",
  bodyFont: "'Merriweather', Georgia, 'Times New Roman', serif",
};

export function truncateText(value: string | null | undefined, maxLength: number): string {
  const normalized = (value ?? '').replace(/\s+/g, ' ').trim();
  if (!normalized) {
    return '';
  }

  if (normalized.length <= maxLength) {
    return normalized;
  }

  return `${normalized.slice(0, Math.max(0, maxLength - 3)).trimEnd()}...`;
}

export function buildCatalogFileName(date = new Date()): string {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `catalogo_allmart_${year}${month}${day}.pdf`;
}

function escapeHtml(value: string): string {
  return value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function toSvgDataUri(svg: string): string {
  return `data:image/svg+xml;base64,${Buffer.from(svg).toString('base64')}`;
}

function decodeDataUri(dataUri: string): Buffer {
  const match = dataUri.match(/^data:([^;,]+)?(?:;charset=[^;,]+)?(;base64)?,(.*)$/i);
  if (!match) {
    throw createError('La imagen embebida no tiene un formato data URI valido', 400);
  }

  const payload = match[3] ?? '';
  if (match[2]) {
    return Buffer.from(payload, 'base64');
  }

  return Buffer.from(decodeURIComponent(payload), 'utf8');
}

function resolveImageUrl(imageUrl: string, baseUrl?: string): string {
  if (/^data:/i.test(imageUrl) || /^https?:\/\//i.test(imageUrl)) {
    return imageUrl;
  }

  if (baseUrl) {
    return new URL(imageUrl, baseUrl).toString();
  }

  return imageUrl;
}

function formatPrice(price: number, currency: string, locale: string): string {
  try {
    return new Intl.NumberFormat(locale, {
      style: 'currency',
      currency,
      maximumFractionDigits: 2,
    }).format(price);
  } catch {
    return `${currency} ${price.toFixed(2)}`;
  }
}

function buildPlaceholderSvg(title: string, branding: CatalogPdfBranding): string {
  const safeTitle = escapeHtml(title || 'Producto');
  return `
    <svg xmlns="http://www.w3.org/2000/svg" width="300" height="300" viewBox="0 0 300 300" role="img" aria-label="Sin imagen para ${safeTitle}">
      <rect width="300" height="300" rx="32" fill="${branding.background}" />
      <rect x="18" y="18" width="264" height="264" rx="26" fill="${branding.surface}" stroke="${branding.border}" stroke-width="4" />
      <circle cx="112" cy="118" r="28" fill="${branding.primaryLight}" opacity="0.95" />
      <path d="M56 226l64-68 38 40 34-32 52 60H56z" fill="${branding.primary}" opacity="0.92" />
      <text x="150" y="256" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" fill="${branding.textSecondary}">Sin imagen</text>
    </svg>
  `;
}

export function normalizeCatalogProduct(
  product: CatalogPdfProductInput,
  locale = 'es-AR',
  defaultCurrency = 'ARS',
): CatalogPdfProduct {
  const title = truncateText(product.title ?? product.name ?? 'Producto sin nombre', MAX_TITLE_LENGTH);
  const price = typeof product.price === 'string' ? Number(product.price) : product.price;

  if (!Number.isFinite(price)) {
    throw createError(`Precio invalido para el producto "${title || 'sin titulo'}"`, 400);
  }

  const currency = (product.currency ?? defaultCurrency).trim() || defaultCurrency;
  const shortDescription = truncateText(
    product.shortDescription ?? product.description ?? '',
    MAX_SHORT_DESCRIPTION_LENGTH,
  );
  const imageUrl = product.imageUrl ?? product.images?.[0] ?? undefined;

  return {
    id: product.id,
    title,
    price,
    currency,
    formattedPrice: formatPrice(price, currency, locale),
    shortDescription,
    imageUrl,
    imageAlt: `Imagen principal de ${title}`,
  };
}

async function fetchImageBuffer(source: string, baseUrl?: string): Promise<Buffer> {
  // Validate that source is a string (should always be, but defensive programming)
  if (typeof source !== 'string' || !source.trim()) {
    throw createError('Source de imagen inválido o vacío', 400);
  }

  if (/^data:/i.test(source)) {
    return decodeDataUri(source);
  }

  // Para imágenes locales de productos o categorías, leer directo desde la DB
  // evitando el overhead (y posibles fallos) de una petición HTTP
  const productImageMatch = source.match(/\/api\/images\/products\/([^/?#]+)/);
  if (productImageMatch) {
    const { data } = await imageStorageService.serveProductImage(productImageMatch[1]);
    return data;
  }

  const categoryImageMatch = source.match(/\/api\/images\/categories\/([^/?#]+)/);
  if (categoryImageMatch) {
    const { data } = await imageStorageService.serveCategoryImage(categoryImageMatch[1]);
    return data;
  }

  const resolvedUrl = resolveImageUrl(source, baseUrl);
  const response = await axios.get<ArrayBuffer>(resolvedUrl, {
    responseType: 'arraybuffer',
    timeout: 20000,
    maxContentLength: 10 * 1024 * 1024,
    validateStatus: (status) => status >= 200 && status < 400,
    headers: {
      'User-Agent': 'Mozilla/5.0 (compatible; Allmart-CatalogBot/1.0; +https://allmart.com)',
      'Accept': 'image/webp,image/avif,image/apng,image/*,*/*;q=0.8',
    },
    maxRedirects: 5,
  });

  return Buffer.from(response.data);
}

async function buildOptimizedImageDataUri(
  imageUrl: string | undefined,
  title: string,
  branding: CatalogPdfBranding,
  baseUrl?: string,
): Promise<string> {
  if (!imageUrl) {
    return toSvgDataUri(buildPlaceholderSvg(title, branding));
  }

  try {
    const rawBuffer = await fetchImageBuffer(imageUrl, baseUrl);
    const optimizedBuffer = await sharp(rawBuffer)
      .rotate()
      .resize({
        width: OPTIMIZED_IMAGE_SIZE,
        height: OPTIMIZED_IMAGE_SIZE,
        fit: 'cover',
        position: 'centre',
        withoutEnlargement: true,
      })
      .flatten({ background: branding.surface })
      .jpeg({ quality: 75, mozjpeg: true })
      .toBuffer();

    return `data:image/jpeg;base64,${optimizedBuffer.toString('base64')}`;
  } catch (err) {
    console.warn(
      `[catalogPdfService] No se pudo cargar la imagen para "${title}":`,
      err instanceof Error ? err.message : String(err),
    );
    return toSvgDataUri(buildPlaceholderSvg(title, branding));
  }
}

async function mapWithConcurrency<TInput, TOutput>(
  items: TInput[],
  concurrency: number,
  mapper: (item: TInput, index: number) => Promise<TOutput>,
): Promise<TOutput[]> {
  if (items.length === 0) {
    return [];
  }

  const results = new Array<TOutput>(items.length);
  let nextIndex = 0;

  const worker = async () => {
    while (nextIndex < items.length) {
      const currentIndex = nextIndex;
      nextIndex += 1;
      results[currentIndex] = await mapper(items[currentIndex], currentIndex);
    }
  };

  const workerCount = Math.min(Math.max(1, concurrency), items.length);
  await Promise.all(Array.from({ length: workerCount }, () => worker()));

  return results;
}

async function prepareProductsForRender(
  products: CatalogPdfProductInput[],
  locale: string,
  defaultCurrency: string,
  branding: CatalogPdfBranding,
  baseUrl?: string,
): Promise<CatalogRenderableProduct[]> {
  const normalizedProducts = products.map((product) => normalizeCatalogProduct(product, locale, defaultCurrency));

  // Evita saturar proveedores externos de imágenes (Unsplash/imgix) cuando el
  // catálogo exporta muchos productos en una sola corrida.
  return mapWithConcurrency(normalizedProducts, IMAGE_PREPARATION_CONCURRENCY, async (product) => ({
    ...product,
    imageDataUri: await buildOptimizedImageDataUri(product.imageUrl, product.title, branding, baseUrl),
  }));
}

export function buildCatalogHtml(options: {
  products: CatalogRenderableProduct[];
  columns: 2 | 3;
  title: string;
  subtitle: string;
  branding?: Partial<CatalogPdfBranding>;
}): string {
  const branding: CatalogPdfBranding = {
    ...DEFAULT_CATALOG_BRANDING,
    ...(options.branding ?? {}),
  };
  const logoDataUri = toSvgDataUri(ALLMART_LOGO_SVG);
  const tableRows = options.products
    .map(
      (product) => `
    <tr>
      <td class="table-image">
        <img src="${product.imageDataUri}" alt="${escapeHtml(product.imageAlt)}" />
      </td>
      <td class="table-title">${escapeHtml(product.title)}</td>
      <td class="table-price">${escapeHtml(product.formattedPrice)}</td>
      <td class="table-description">${escapeHtml(product.shortDescription || 'Sin descripcion breve.')}</td>
    </tr>
  `,
    )
    .join('');

  return `
    <!doctype html>
    <html lang="es">
      <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <style>
          :root {
            --brand-primary: ${branding.primary};
            --brand-primary-dark: ${branding.primaryDark};
            --brand-accent: ${branding.accent};
            --brand-accent-dark: ${branding.accentDark};
            --brand-background: ${branding.background};
            --brand-surface: ${branding.surface};
            --brand-border: ${branding.border};
            --brand-text: ${branding.textPrimary};
            --brand-text-muted: ${branding.textSecondary};
            --font-heading: ${branding.headingFont};
            --font-body: ${branding.bodyFont};
          }
          * { box-sizing: border-box; }
          html, body {
            margin: 0; padding: 0;
            color: var(--brand-text);
            background: var(--brand-background);
            font-family: var(--font-body);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
          }
          .catalog-shell { padding: 5mm; }
          .catalog-hero {
            background: linear-gradient(135deg, var(--brand-primary-dark), var(--brand-primary));
            border-radius: 18px;
            color: #fff;
            display: grid;
            gap: 10px;
            grid-template-columns: 112px 1fr;
            padding: 18px 22px;
            align-items: center;
            box-shadow: 0 18px 32px rgba(93,117,104,0.14);
          }
          .catalog-hero__logo { max-width: 100%; display: block; }
          .catalog-hero__eyebrow {
            font: 600 11px/1.2 var(--font-heading);
            letter-spacing: 0.18em;
            margin: 0 0 8px;
            opacity: 0.74;
            text-transform: uppercase;
          }
          .catalog-hero__title {
            font: 700 28px/1.05 var(--font-heading);
            letter-spacing: -0.02em;
            margin: 0;
          }
          .catalog-hero__subtitle {
            font: 400 13px/1.55 var(--font-body);
            margin: 10px 0 0;
            max-width: 560px;
          }
          .catalog-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 10mm;
            background: var(--brand-surface);
            border-radius: 14px;
            box-shadow: 0 8px 24px rgba(26,26,26,0.07);
            overflow: hidden;
          }
          .catalog-table th, .catalog-table td {
            padding: 4px 8px;
            border-bottom: 1px solid var(--brand-border);
            vertical-align: middle;
            text-align: left;
            font-size: 10pt;
          }
          .catalog-table th {
            background: var(--brand-primary);
            color: #fff;
            font: 700 10.5pt var(--font-heading);
            letter-spacing: 0.01em;
            border-bottom: 2px solid var(--brand-primary-dark);
            padding-top: 7px;
            padding-bottom: 7px;
          }
          .catalog-table tr:last-child td { border-bottom: none; }
          .table-image {
            width: 22mm;
            min-width: 18mm;
            text-align: center;
            padding: 3px 6px;
          }
          .table-image img {
            width: 18mm;
            height: 18mm;
            object-fit: cover;
            border-radius: 6px;
            background: var(--brand-background);
            border: 1px solid var(--brand-border);
            display: block;
          }
          .table-title {
            font: 700 10pt var(--font-heading);
            color: var(--brand-text);
            max-width: 52mm;
            word-break: break-word;
          }
          .table-price {
            color: var(--brand-accent-dark);
            font: 700 10pt var(--font-heading);
            white-space: nowrap;
          }
          .table-description {
            color: var(--brand-text-muted);
            font: 400 9.5pt var(--font-body);
            word-break: break-word;
          }
          @media print { .catalog-shell { padding: 0; } }
        </style>
      </head>
      <body>
        <main class="catalog-shell">
          <section class="catalog-hero" aria-label="Encabezado del catalogo">
            <img class="catalog-hero__logo" src="${logoDataUri}" alt="Logo de Allmart" />
            <div>
              <p class="catalog-hero__eyebrow">Allmart</p>
              <h1 class="catalog-hero__title">${escapeHtml(options.title)}</h1>
              ${options.subtitle ? `<p class="catalog-hero__subtitle">${escapeHtml(options.subtitle)}</p>` : ''}
            </div>
          </section>
          <section aria-label="Catalogo de productos">
            <table class="catalog-table">
              <thead>
                <tr>
                  <th>Imagen</th>
                  <th>Nombre</th>
                  <th>Precio</th>
                  <th>Descripcion</th>
                </tr>
              </thead>
              <tbody>
                ${tableRows}
              </tbody>
            </table>
          </section>
        </main>
      </body>
    </html>
  `;
}

