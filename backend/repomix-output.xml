import nodemailer, { type Transporter } from 'nodemailer';
import { env } from '../config/env';

interface OrderConfirmationEmailItem {
  productName: string;
  quantity: number;
  unitPrice: number;
}

interface OrderConfirmationEmailInput {
  orderId: string;
  createdAt: Date;
