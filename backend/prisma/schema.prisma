generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 1. USUARIOS Y CRM
// ============================================================================

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(30) // <-- Asegúrate que tenga el ?
  passwordHash String?   @map("password_hash") // <-- Asegúrate que tenga el ?
  role         UserRole  @default(editor)
  isActive     Boolean   @default(true) @map("is_active")  
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart         Cart?
  favorites    Favorite[]
  reviews      ProductReview[]
  staffNotes   StaffNote[]
  priceChanges SupplierProductPrice[] @relation("SupplierProductPriceChangedBy")
  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model Customer {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(30)
  totalOrders  Int       @default(0) @map("total_orders")
  totalSpent   Decimal   @default(0) @db.Decimal(12, 2) @map("total_spent")
  
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  orders       Order[]

  @@map("customers")
}

// ============================================================================
// 2. CATÁLOGO DE PRODUCTOS, SKUS, ETIQUETAS Y CARACTERÍSTICAS
// ============================================================================

model Category {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String                @db.VarChar(150)
  slug              String                @unique(map: "categories_slug_unique") @db.VarChar(150)
  description       String?
  imageUrl          String?               @map("image_url")
  parentId          String?               @map("parent_id") @db.Uuid
  itemCount         Int                   @default(0) @map("item_count")
  isVisible         Boolean               @default(true) @map("is_visible")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  parent            Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id], onUpdate: NoAction, map: "categories_parent_fk")
  children          Category[]            @relation("CategoryHierarchy")
  categoryImage     CategoryImageStorage?
  productCategories ProductCategory[]
  promotionRules    PromotionRule[]

  @@index([slug], map: "idx_categories_slug")
  @@index([parentId], map: "idx_categories_parent_id")
  @@map("categories")
}

model Product {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                 @db.VarChar(255)
  slug                  String                 @unique(map: "products_slug_unique") @db.VarChar(255)
  description           String?
  shortDescription      String?                @map("short_description")
  price                 Decimal                @db.Decimal(12, 2)
  images                Json                   @default("[]")
  rating                Decimal                @default(0) @db.Decimal(3, 2)
  reviewCount           Int                    @default(0) @map("review_count")
  inStock               Boolean                @default(true) @map("in_stock")
  stock                 Int                    @default(0)
  sku                   String?                @unique(map: "products_sku_unique") @db.VarChar(100)
  isFeatured            Boolean                @default(false) @map("is_featured")
  status                ProductStatus          @default(active)
  primarySupplierId     String?                @map("primary_supplier_id") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  novedadSince          DateTime?              @map("novedad_since") @db.Timestamptz(6)
  
  cartItems             CartItem[]
  collectionItems       CollectionItem[]
  favorites             Favorite[]
  lowStockAlerts        LowStockAlert[]
  orderItems            OrderItem[]
  productCategories     ProductCategory[]
  productImages         ProductImageStorage[]
  productOptions        ProductOption[]
  reviews               ProductReview[]
  productSkus           ProductSku[]
  productSuppliers      ProductSupplier[]
  primarySupplier       Supplier?              @relation("ProductPrimarySupplier", fields: [primarySupplierId], references: [id], onUpdate: NoAction, map: "products_primary_supplier_fk")
  promotionRules        PromotionRule[]
  supplierProductPrices SupplierProductPrice[]
  productTags           ProductTag[]
  productFeatures       ProductFeature[]

  @@index([sku], map: "idx_products_sku")
  @@index([slug], map: "idx_products_slug")
  @@index([status], map: "idx_products_status")
  @@index([isFeatured], map: "idx_products_is_featured")
  @@map("products")
}

model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_categories_category_fk")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_categories_product_fk")

  @@id([productId, categoryId])
  @@index([categoryId], map: "idx_product_categories_category_id")
  @@index([productId], map: "idx_product_categories_product_id")
  @@map("product_categories")
}

model Tag {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String       @unique @db.VarChar(100)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  
  productTags ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String   @map("product_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_tags_product_fk")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_tags_tag_fk")

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductFeature {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  description  String   @db.VarChar(500)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_features_product_fk")

  @@index([productId])
  @@map("product_features")
}

model ProductOption {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String               @map("product_id") @db.Uuid
  name      String               @db.VarChar(100)
  isActive  Boolean              @default(true) @map("is_active")
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  values    ProductOptionValue[]
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([productId, name])
  @@index([productId], map: "idx_product_options_product_id")
  @@map("product_options")
}

model ProductOptionValue {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  optionId  String            @map("option_id") @db.Uuid
  name      String            @db.VarChar(100)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  option    ProductOption     @relation(fields: [optionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  skuValues ProductSkuValue[]

  @@unique([optionId, name])
  @@index([optionId], map: "idx_product_option_values_option_id")
  @@map("product_option_values")
}

model ProductSku {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String                   @map("product_id") @db.Uuid
  sku              String                   @unique(map: "product_skus_sku_unique") @db.VarChar(100)
  stock            Int                      @default(0)
  price            Decimal?                 @db.Decimal(12, 2)
  isActive         Boolean                  @default(true) @map("is_active")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  product          Product                  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_skus_product_fk")
  productSkuImages ProductSkuImageStorage[]
  skuValues        ProductSkuValue[]
  orderItems       OrderItem[]              // Relación inversa para trazabilidad transaccional

  @@index([productId], map: "idx_product_skus_product_id")
  @@map("product_skus")
}

model ProductSkuValue {
  skuId         String             @map("sku_id") @db.Uuid
  optionValueId String             @map("option_value_id") @db.Uuid
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sku           ProductSku         @relation(fields: [skuId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([skuId, optionValueId])
  @@map("product_sku_values")
}

// ============================================================================
// 3. STORAGE DE IMÁGENES
// ============================================================================

model ProductImageStorage {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String   @map("product_id") @db.Uuid

  // --- CAMPOS NUEVOS FASE 2 ---
  storageKey       String?  @map("storage_key") @db.VarChar(500)
  storageThumbKey  String?  @map("storage_thumb_key") @db.VarChar(500)  
  width            Int
  height           Int
  thumbWidth       Int?     @map("thumb_width")
  thumbHeight      Int?     @map("thumb_height")
  mimeType         String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  sizeBytes        Int      @map("size_bytes")
  altText          String?  @map("alt_text") @db.VarChar(500)
  position         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_images_storage_product_fk")

  @@index([productId], map: "idx_product_images_product_id")
  @@index([productId, position], map: "idx_product_images_position")
  @@map("product_images_storage")
}

model ProductSkuImageStorage {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  skuId            String     @map("sku_id") @db.Uuid

  // --- CAMPOS NUEVOS FASE 2 ---
  storageKey       String?    @map("storage_key") @db.VarChar(500)
  storageThumbKey  String?    @map("storage_thumb_key") @db.VarChar(500)
  width            Int
  height           Int
  thumbWidth       Int?       @map("thumb_width")
  thumbHeight      Int?       @map("thumb_height")
  mimeType         String     @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?    @map("original_filename") @db.VarChar(255)
  sizeBytes        Int        @map("size_bytes")
  altText          String?    @map("alt_text") @db.VarChar(500)
  position         Int        @default(0)
  isPrimary        Boolean    @default(false) @map("is_primary")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  sku              ProductSku @relation(fields: [skuId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_sku_images_sku_fk")

  @@index([skuId], map: "idx_product_sku_images_sku_id")
  @@index([skuId, position], map: "idx_product_sku_images_position")
  @@map("product_sku_images_storage")
}

model CategoryImageStorage {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String   @unique @map("category_id") @db.Uuid

  // --- CAMPOS NUEVOS FASE 2 ---
  storageKey       String?  @map("storage_key") @db.VarChar(500)
  storageThumbKey  String?  @map("storage_thumb_key") @db.VarChar(500)
  width            Int
  height           Int
  thumbWidth       Int?     @map("thumb_width")
  thumbHeight      Int?     @map("thumb_height")
  mimeType         String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  sizeBytes        Int      @map("size_bytes")
  altText          String?  @map("alt_text") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "category_images_storage_category_fk")

  @@map("category_images_storage")
}

// ============================================================================
// 4. TRANSACCIONES Y PEDIDOS
// ============================================================================

model Order {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Vínculo al nuevo modelo User (CRM)
  customerId         String?              @map("customer_id") @db.Uuid
  customerRel        Customer?            @relation(fields: [customerId], references: [id], onUpdate: NoAction, map: "orders_customer_fk")

  // Snapshot de datos del cliente al momento de la compra (inmutable)
  customerFirstName  String               @map("customer_first_name") @db.VarChar(100)
  customerLastName   String               @map("customer_last_name") @db.VarChar(100)
  customerEmail      String               @map("customer_email") @db.VarChar(255)
  customerPhone      String?              @map("customer_phone") @db.VarChar(30)
  
  total              Decimal              @default(0) @db.Decimal(12, 2)
  status             OrderStatus          @default(pendiente)
  paymentStatus      PaymentStatus        @default(no_abonado) @map("payment_status")
  paidAt             DateTime?            @map("paid_at") @db.Timestamptz(6)
  notes              String?
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  lowStockAlerts     LowStockAlert[]
  orderItems         OrderItem[]
  orderStatusHistory OrderStatusHistory[]
  reviews            ProductReview[]
  shipment           Shipment?

  @@index([customerId], map: "idx_orders_customer_id") // Antes decía [userId]
  @@index([createdAt], map: "idx_orders_created_at")
  @@index([customerEmail], map: "idx_orders_customer_email")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

model OrderItem {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String      @map("order_id") @db.Uuid
  productId    String?     @map("product_id") @db.Uuid
  productSkuId String?     @map("product_sku_id") @db.Uuid // Campo opcional y mapeado como UUID
  productName  String      @map("product_name") @db.VarChar(255)
  productImage String?     @map("product_image")
  quantity     Int
  unitPrice    Decimal     @db.Decimal(12, 2) @map("unit_price")

  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_items_order_fk")
  product      Product?    @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "order_items_product_fk")
  productSku   ProductSku? @relation(fields: [productSkuId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "order_items_sku_fk") // Relación de auditoría segura

  @@index([orderId], map: "idx_order_items_order_id")
  @@index([productSkuId], map: "idx_order_items_sku_id") // Índice para optimizar consultas de variantes
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  changedAt DateTime    @default(now()) @map("changed_at") @db.Timestamptz(6)
  note      String?
  
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_status_history_order_fk")

  @@index([orderId], map: "idx_order_status_history_order_id")
  @@map("order_status_history")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @unique(map: "carts_user_unique") @map("user_id") @db.Uuid
  sessionId String?    @map("session_id") @db.VarChar(255)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  cartItems CartItem[]
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "carts_user_fk")

  @@index([sessionId], map: "idx_carts_session_id")
  @@index([userId], map: "idx_carts_user_id")
  @@map("carts")
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cart_items_cart_fk")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cart_items_product_fk")

  @@unique([cartId, productId], map: "cart_items_unique_product")
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

model Shipment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @unique(map: "shipments_order_unique") @map("order_id") @db.Uuid
  addressStreet   String    @map("address_street") @db.VarChar(255)
  addressCity     String    @map("address_city") @db.VarChar(150)
  addressProvince String    @map("address_province") @db.VarChar(150)
  addressZip      String    @map("address_zip") @db.VarChar(20)
  carrier         String?   @db.VarChar(100)
  trackingNumber  String?   @map("tracking_number") @db.VarChar(100)
  status          String    @default("pending") @db.VarChar(50)
  shippedAt       DateTime? @map("shipped_at") @db.Timestamptz(6)
  deliveredAt     DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shipments_order_fk")

  @@index([orderId], map: "idx_shipments_order_id")
  @@index([trackingNumber], map: "idx_shipments_tracking_number")
  @@map("shipments")
}

// ============================================================================
// 5. COLECCIONES, PROMOCIONES Y EXTRAS
// ============================================================================

model SchemaMigration {
  id        Int      @id @default(autoincrement())
  filename  String   @unique @db.VarChar(255)
  appliedAt DateTime @default(now()) @map("applied_at") @db.Timestamptz(6)

  @@map("schema_migrations")
}

model StaffNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId    String   @map("user_id") @db.Uuid
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "staff_notes_user_fk")

  @@index([userId], map: "idx_staff_notes_user_id")
  @@map("staff_notes")
}

model Promotion {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String          @db.VarChar(255)
  description       String?
  type              PromotionType
  value             Decimal         @db.Decimal(12, 2)
  startDate         DateTime        @map("start_date") @db.Timestamptz(6)
  endDate           DateTime        @map("end_date") @db.Timestamptz(6)
  minPurchaseAmount Decimal?        @map("min_purchase_amount") @db.Decimal(12, 2)
  maxDiscount       Decimal?        @map("max_discount") @db.Decimal(12, 2)
  isActive          Boolean         @default(true) @map("is_active")
  priority          Int             @default(0)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  promotionRules    PromotionRule[]

  @@index([isActive], map: "idx_promotions_is_active")
  @@index([startDate, endDate], map: "idx_promotions_dates")
  @@index([priority], map: "idx_promotions_priority")
  @@map("promotions")
}

model PromotionRule {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promotionId String    @map("promotion_id") @db.Uuid
  productId   String?   @map("product_id") @db.Uuid
  categoryId  String?   @map("category_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "promotion_rules_category_fk")
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "promotion_rules_product_fk")
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "promotion_rules_promotion_fk")

  @@unique([promotionId, productId, categoryId], map: "promotion_rules_unique")
  @@index([promotionId], map: "idx_promotion_rules_promotion_id")
  @@index([productId], map: "idx_promotion_rules_product_id")
  @@index([categoryId], map: "idx_promotion_rules_category_id")
  @@map("promotion_rules")
}

model Collection {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String                    @db.VarChar(255)
  slug            String                    @unique(map: "collections_slug_unique") @db.VarChar(255)
  description     String?
  displayOrder    Int                       @default(0) @map("display_order")
  displayPosition CollectionDisplayPosition @map("display_position")
  imageUrl        String?                   @map("image_url")
  isActive        Boolean                   @default(true) @map("is_active")
  type            String                    @default("manual") @db.VarChar(20)
  params          Json                      @default("{}")
  snapshotAt      DateTime?                 @map("snapshot_at") @db.Timestamptz(6)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  collectionItems CollectionItem[]

  @@index([slug], map: "idx_collections_slug")
  @@index([isActive], map: "idx_collections_is_active")
  @@index([displayPosition], map: "idx_collections_display_position")
  @@index([type], map: "idx_collections_type")
  @@index([displayPosition, displayOrder], map: "idx_collections_active_home", where: raw("(is_active = true)"))
  @@map("collections")
}

model CollectionItem {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  collectionId String     @map("collection_id") @db.Uuid
  productId    String     @map("product_id") @db.Uuid
  position     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "collection_items_collection_fk")
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "collection_items_product_fk")

  @@unique([collectionId, productId], map: "collection_items_unique")
  @@index([collectionId], map: "idx_collection_items_collection_id")
  @@index([productId], map: "idx_collection_items_product_id")
  @@map("collection_items")
}

model LowStockAlert {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  productName  String   @map("product_name") @db.VarChar(255)
  quantitySold Int      @map("quantity_sold")
  stockBefore  Int      @map("stock_before")
  stockAfter   Int      @map("stock_after")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "low_stock_alerts_order_fk")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "low_stock_alerts_product_fk")

  @@index([orderId], map: "idx_low_stock_alerts_order_id")
  @@index([productId], map: "idx_low_stock_alerts_product_id")
  @@index([createdAt], map: "idx_low_stock_alerts_created_at")
  @@map("low_stock_alerts")
}

model Banner {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String   @db.VarChar(255)
  description      String?
  filterConfig     Json     @default("{}") @map("filter_config")

  // --- CAMPOS NUEVOS FASE 2 ---
  storageKey       String?  @map("storage_key") @db.VarChar(500)
  storageThumbKey  String?  @map("storage_thumb_key") @db.VarChar(500)
  width            Int
  height           Int
  thumbWidth       Int?     @map("thumb_width")
  thumbHeight      Int?     @map("thumb_height")
  mimeType         String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  sizeBytes        Int      @map("size_bytes")
  altText          String?  @map("alt_text") @db.VarChar(500)
  displayOrder     Int      @default(0) @map("display_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isPinned         Boolean  @default(false) @map("is_pinned")

  @@index([isActive], map: "idx_banners_is_active")
  @@index([isPinned], map: "idx_banners_is_pinned")
  @@index([displayOrder], map: "idx_banners_display_order")
  @@map("banners")
}

model ProductReview {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  orderId      String?  @map("order_id") @db.Uuid
  reviewerName String?  @map("reviewer_name") @db.VarChar(100)
  rating       Int
  title        String?  @db.VarChar(255)
  text         String?
  helpful      Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  order        Order?   @relation(fields: [orderId], references: [id], onUpdate: NoAction, map: "product_reviews_order_fk")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_reviews_product_fk")
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_reviews_user_fk")

  @@unique([productId, userId], map: "product_reviews_unique")
  @@unique([productId, orderId], map: "product_reviews_order_unique")
  @@index([productId], map: "idx_product_reviews_product_id")
  @@index([userId], map: "idx_product_reviews_user_id")
  @@index([orderId], map: "idx_product_reviews_order_id")
  @@map("product_reviews")
}

model Favorite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "favorites_product_fk")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "favorites_user_fk")

  @@unique([userId, productId], map: "favorites_unique")
  @@index([userId], map: "idx_favorites_user_id")
  @@index([productId], map: "idx_favorites_product_id")
  @@map("favorites")
}

model Supplier {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String                 @db.VarChar(255)
  url              String?                @db.VarChar(500)
  phone            String                 @db.VarChar(50)
  address          String                 @db.VarChar(500)
  email            String?                @db.VarChar(255)
  description      String?
  isActive         Boolean                @default(true) @map("is_active")
  products         String                 @default("")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  productSuppliers ProductSupplier[]
  primaryProducts  Product[]              @relation("ProductPrimarySupplier")
  priceHistory     SupplierProductPrice[]

  @@index([name], map: "idx_suppliers_name")
  @@index([isActive], map: "idx_suppliers_is_active")
  @@map("suppliers")
}

model ProductSupplier {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  currentPrice Decimal  @map("current_price") @db.Decimal(12, 2)
  cost         Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_suppliers_product_fk")
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_suppliers_supplier_fk")

  @@unique([productId, supplierId], map: "product_suppliers_unique")
  @@index([productId], map: "idx_product_suppliers_product_id")
  @@index([supplierId], map: "idx_product_suppliers_supplier_id")
  @@map("product_suppliers")
}

model SupplierProductPrice {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  price         Decimal  @db.Decimal(12, 2)
  cost          Decimal? @db.Decimal(12, 2)
  changeReason  String   @default("regular") @map("change_reason") @db.VarChar(50)
  changedBy     String?  @map("changed_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "supplier_product_prices_product_fk")
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "supplier_product_prices_supplier_fk")
  changedByUser User?    @relation("SupplierProductPriceChangedBy", fields: [changedBy], references: [id], onUpdate: NoAction, map: "supplier_product_prices_user_fk")

  @@index([productId, supplierId, createdAt(sort: Desc)], map: "idx_supplier_product_prices_main")
  @@index([supplierId, createdAt(sort: Desc)], map: "idx_supplier_product_prices_supplier")
  @@map("supplier_product_prices")
}

model Contact {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(150)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(30)
  message    String
  status     String   @default("unread") @db.VarChar(50)
  isFlagged  Boolean  @default(false) @map("is_flagged")
  adminNotes String?  @map("admin_notes")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email], map: "idx_contacts_email")
  @@index([status], map: "idx_contacts_status")
  @@index([isFlagged], map: "idx_contacts_is_flagged")
  @@index([createdAt], map: "idx_contacts_created_at")
  @@map("contacts")
}

