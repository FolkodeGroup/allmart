generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  editor
  customer

  @@map("user_role")
}

enum OrderStatus {
  pendiente
  confirmado
  en_preparacion  @map("en-preparacion")
  enviado
  entregado
  cancelado

  @@map("order_status")
}

enum PaymentStatus {
  no_abonado  @map("no-abonado")
  abonado

  @@map("payment_status")
}

enum ProductStatus {
  active
  inactive
  draft
  archived

  @@map("product_status")
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  email        String   @unique(map: "users_email_unique") @db.VarChar(255)
  passwordHash String   @map("password_hash")
  role         UserRole @default(customer)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cart         Cart?
  staffNotes   StaffNote[]
  
  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@map("users")
  
}

model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(150)
  slug        String    @unique(map: "categories_slug_unique") @db.VarChar(150)
  description String?
  imageUrl    String?   @map("image_url")
  itemCount   Int       @default(0) @map("item_count")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  products    Product[]
  categoryImage CategoryImageStorage?

  @@index([slug], map: "idx_categories_slug")
  @@map("categories")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Product {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String           @db.VarChar(255)
  slug             String           @unique(map: "products_slug_unique") @db.VarChar(255)
  description      String?
  shortDescription String?          @map("short_description")
  price            Decimal          @db.Decimal(12, 2)
  originalPrice    Decimal?         @map("original_price") @db.Decimal(12, 2)
  discount         Decimal?         @db.Decimal(5, 2)
  images           Json             @default("[]")
  categoryId       String?          @map("category_id") @db.Uuid
  tags             Json             @default("[]")
  rating           Decimal          @default(0) @db.Decimal(3, 2)
  reviewCount      Int              @default(0) @map("review_count")
  inStock          Boolean          @default(true) @map("in_stock")
  stock            Int              @default(0)
  sku              String?          @unique(map: "products_sku_unique") @db.VarChar(100)
  features         Json             @default("[]")
  status           ProductStatus    @default(active)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cartItems        CartItem[]
  orderItems       OrderItem[]
  productVariants  ProductVariant[]
  productImages    ProductImageStorage[]
  category         Category?        @relation(fields: [categoryId], references: [id], onUpdate: NoAction, map: "products_category_fk")

  @@index([categoryId], map: "idx_products_category_id")
  @@index([sku], map: "idx_products_sku")
  @@index([slug], map: "idx_products_slug")
  @@index([status], map: "idx_products_status")
  @@map("products")
}

/// Imagen de producto almacenada en binario WebP en base de datos
model ProductImageStorage {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  data             Bytes                               // WebP completo
  width            Int
  height           Int
  thumbnail        Bytes?                              // WebP miniatura ~200px
  thumbWidth       Int?     @map("thumb_width")
  thumbHeight      Int?     @map("thumb_height")
  mimeType         String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  sizeBytes        Int      @map("size_bytes")
  altText          String?  @map("alt_text") @db.VarChar(500)
  position         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_images_storage_product_fk")

  @@index([productId], map: "idx_product_images_product_id")
  @@index([productId, position], map: "idx_product_images_position")
  @@map("product_images_storage")
}

/// Imagen de categoría almacenada en binario WebP (una por categoría)
model CategoryImageStorage {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String   @unique @map("category_id") @db.Uuid
  data             Bytes                               // WebP completo
  width            Int
  height           Int
  thumbnail        Bytes?
  thumbWidth       Int?     @map("thumb_width")
  thumbHeight      Int?     @map("thumb_height")
  mimeType         String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  sizeBytes        Int      @map("size_bytes")
  altText          String?  @map("alt_text") @db.VarChar(500)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "category_images_storage_category_fk")

  @@map("category_images_storage")
}

model ProductVariant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  name      String   @db.VarChar(100)
  values    Json     @default("[]")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_variants_product_fk")

  @@index([isActive], map: "idx_product_variants_is_active")
  @@index([name], map: "idx_product_variants_name")
  @@index([productId], map: "idx_product_variants_product_id")
  @@map("product_variants")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Order {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerFirstName   String               @map("customer_first_name") @db.VarChar(100)
  customerLastName    String               @map("customer_last_name") @db.VarChar(100)
  customerEmail       String               @map("customer_email") @db.VarChar(255)
  total               Decimal              @default(0) @db.Decimal(12, 2)
  status              OrderStatus          @default(pendiente)
  paymentStatus       PaymentStatus        @default(no_abonado) @map("payment_status")
  paidAt              DateTime?            @map("paid_at") @db.Timestamptz(6)
  notes               String?
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  orderItems          OrderItem[]
  orderStatusHistory  OrderStatusHistory[]
  sale                Sale?
  shipment            Shipment?

  @@index([createdAt], map: "idx_orders_created_at")
  @@index([customerEmail], map: "idx_orders_customer_email")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId    String?  @map("product_id") @db.Uuid
  productName  String   @map("product_name") @db.VarChar(255)
  productImage String?  @map("product_image")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_items_order_fk")
  product      Product? @relation(fields: [productId], references: [id], onUpdate: NoAction, map: "order_items_product_fk")

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  changedAt DateTime    @default(now()) @map("changed_at") @db.Timestamptz(6)
  note      String?
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_status_history_order_fk")

  @@index([orderId], map: "idx_order_status_history_order_id")
  @@map("order_status_history")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?    @unique(map: "carts_user_unique") @map("user_id") @db.Uuid
  sessionId String?    @map("session_id") @db.VarChar(255)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cartItems CartItem[]
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "carts_user_fk")

  @@index([sessionId], map: "idx_carts_session_id")
  @@index([userId], map: "idx_carts_user_id")
  @@map("carts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cart_items_cart_fk")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cart_items_product_fk")

  @@unique([cartId, productId], map: "cart_items_unique_product")
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Sale {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @unique(map: "sales_order_unique") @map("order_id") @db.Uuid
  total     Decimal  @db.Decimal(12, 2)
  soldAt    DateTime @default(now()) @map("sold_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sales_order_fk")

  @@index([soldAt], map: "idx_sales_sold_at")
  @@map("sales")
}

model Shipment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @unique(map: "shipments_order_unique") @map("order_id") @db.Uuid
  addressStreet   String    @map("address_street") @db.VarChar(255)
  addressCity     String    @map("address_city") @db.VarChar(150)
  addressProvince String    @map("address_province") @db.VarChar(150)
  addressZip      String    @map("address_zip") @db.VarChar(20)
  carrier         String?   @db.VarChar(100)
  trackingNumber  String?   @map("tracking_number") @db.VarChar(100)
  status          String    @default("pending") @db.VarChar(50)
  shippedAt       DateTime? @map("shipped_at") @db.Timestamptz(6)
  deliveredAt     DateTime? @map("delivered_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shipments_order_fk")

  @@index([orderId], map: "idx_shipments_order_id")
  @@index([trackingNumber], map: "idx_shipments_tracking_number")
  @@map("shipments")
}

model SchemaMigration {
  id        Int      @id @default(autoincrement())
  filename  String   @unique @db.VarChar(255)
  appliedAt DateTime @default(now()) @map("applied_at") @db.Timestamptz(6)

  @@map("schema_migrations")
}

// ─── Staff Notes ─────────────────────────────────────────────────────────────

model StaffNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "staff_notes_user_fk")

  @@index([userId], map: "idx_staff_notes_user_id")
  @@map("staff_notes")
}
