enum UserRole {
  admin
  editor
  @@map("user_role")
}

enum OrderStatus {
  pendiente
  confirmado
  en_preparacion @map("en-preparacion")
  enviado
  entregado
  cancelado

  @@map("order_status")
}

enum PaymentStatus {
  no_abonado @map("no-abonado")
  abonado

  @@map("payment_status")
}

enum ProductStatus {
  active
  inactive
  draft
  archived

  @@map("product_status")
}

enum PromotionType {
  percentage
  fixed
  bogo

  @@map("promotion_type")
}

enum CollectionDisplayPosition {
  home
  category

  @@map("collection_display_position")
}

enum CollectionType {
  manual
  auto_sales

  @@map("collection_type")
}