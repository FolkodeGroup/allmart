# ─────────────────────────────────────────────────────────────────────────────
# Allmart Backend — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3001                     # Puerto en el que escucha Express

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173   # URL del frontend permitida

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_en_produccion   # Clave de firma de tokens JWT
JWT_EXPIRES_IN=8h                              # Duración del token (opcional)

# ─── Credenciales Admin (in-memory hasta integrar BD) ────────────────────────
# Genera un hash con: node -e "require('bcryptjs').hash('tu_password',10).then(console.log)"
ADMIN_USER=admin
ADMIN_HASH=$2b$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

EDITOR_USER=editor
EDITOR_HASH=$2b$10$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Base de datos (descomentar cuando se integre) ────────────────────────────
# Selecciona UNA según el motor elegido:

# PostgreSQL (con pg / Prisma / TypeORM)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/allmart_db

# MongoDB (con Mongoose)
# DATABASE_URL=mongodb://localhost:27017/allmart_db

# MySQL / MariaDB
# DATABASE_URL=mysql://usuario:password@localhost:3306/allmart_db
