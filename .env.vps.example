# =============================================================================
# Allmart — Variables de entorno para producción en VPS (DonWeb)
#
# Copia este archivo como .env en la raíz del proyecto en el VPS:
#   cp .env.vps.example .env
#
# Luego edita los valores con credenciales reales.
# NUNCA subas el archivo .env al repositorio.
# Este archivo (.env.vps.example) no contiene datos sensibles reales.
# =============================================================================

# ─── Imagen Docker (tag a desplegar) ──────────────────────────────────────────
IMAGE_TAG=latest

# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
DB_USER=allmart_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_NAME=allmart_db
# Puerto expuesto en el VPS (5433 para no conflictuar con otros proyectos)
DB_PORT_HOST=5433

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# Puerto expuesto en el VPS (3002 para no conflictuar con otros proyectos)
BACKEND_PORT=3002
JWT_SECRET=CAMBIAR_POR_SECRET_LARGO_Y_ALEATORIO_MIN_64_CHARS
# URL del frontend (IP del VPS + puerto del frontend)
CORS_ORIGIN=http://168.197.49.120:8082

# ─── Datos iniciales (Seed) ───────────────────────────────────────────────────
# Contraseñas con las que se crearán los usuarios admin@admin.com y editor@admin.com
SEED_ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_ADMIN_SEGURO
SEED_EDITOR_PASSWORD=CAMBIAR_POR_PASSWORD_EDITOR_SEGURO

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Puerto expuesto en el VPS (8082 para no conflictuar con otros proyectos)
FRONTEND_PORT=8082
