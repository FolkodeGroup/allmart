#!/bin/bash

# Colores para la salida
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # Sin color

echo -e "${YELLOW}Iniciando validaciones pre-push en Allmart (Beast Mode)... ${NC}"

# Función para manejar errores de forma inmediata
fail_on_error() {
  local status=$1
  local message=$2
  if [ $status -ne 0 ]; then
    echo -e "${RED}ERROR: $message${NC}"
    exit 1
  fi
}

ROOT_DIR=$(pwd)

# 1. Prisma generate (Backend)
echo -e "${YELLOW}Ejecutando prisma generate...${NC}"
cd "$ROOT_DIR/backend" && npx prisma generate
fail_on_error $? "Prisma generate falló en el backend."

# 2. Lint (Backend & Frontend)
echo -e "${YELLOW}Ejecutando lint en backend...${NC}"
cd "$ROOT_DIR/backend" && npm run lint
fail_on_error $? "Lint falló en el backend. Corrige los errores antes de empujar."

echo -e "${YELLOW}Ejecutando lint en frontend...${NC}"
cd "$ROOT_DIR/frontend" && npm run lint
fail_on_error $? "Lint falló en el frontend (App.tsx u otro). Corrige el error antes de empujar."

# 3. Tests (Backend & Frontend)
echo -e "${YELLOW}Ejecutando tests en backend...${NC}"
cd "$ROOT_DIR/backend" && npm test -- --bail
fail_on_error $? "Los tests fallaron en el backend."

echo -e "${YELLOW}Ejecutando tests en frontend...${NC}"
cd "$ROOT_DIR/frontend" && npm test -- --bail
fail_on_error $? "Los tests fallaron en el frontend."

# 4. Build (Backend & Frontend)
echo -e "${YELLOW}Validando build de backend...${NC}"
cd "$ROOT_DIR/backend" && npm run build
fail_on_error $? "El build del backend falló."

echo -e "${YELLOW}Validando build de frontend...${NC}"
cd "$ROOT_DIR/frontend" && npm run build
fail_on_error $? "El build del frontend falló."

echo -e "${GREEN}¡Validaciones exitosas! Allmart está listo para el push.${NC}"
exit 0
