# =============================================================================
# Allmart — Variables de entorno para DESARROLLO LOCAL (Docker Compose)
#
# Pasos:
#   1. Copia este archivo como .env en la RAÍZ del proyecto:
#        cp .env.docker.example .env          (Linux/Mac/WSL)
#        copy .env.docker.example .env        (Windows CMD)
#
#   2. Levanta los contenedores:
#        docker compose up -d
#
#   3. Accede a:
#        Frontend:  http://localhost:8080
#        Backend:   http://localhost:3001/api
#
# NUNCA subas el archivo .env al repositorio.
# Las credenciales de producción van en GitHub Secrets.
# =============================================================================

# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=allmart_db
DB_PORT_HOST=5432           # Puerto expuesto en tu máquina (cambia si ya usas 5432)

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001           # Puerto expuesto en tu máquina para el backend
JWT_SECRET=dev_jwt_secret_cambia_en_produccion
CORS_ORIGIN=http://localhost:8080

# ─── Prisma (usa los valores de DB_* de arriba) ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/allmart_db?schema=public

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080          # Puerto donde accedes a la app en el navegador
